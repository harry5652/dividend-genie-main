modules = ["python-base-3.13"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "source .venv/bin/activate && python -m app.main"

[workflows.workflow.metadata]
outputType = "console"

[userenv]

[userenv.shared]
ADMIN_TELEGRAM_ID = "@harry5652"
