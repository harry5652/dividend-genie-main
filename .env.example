# Copy this file to .env and fill in real values.
# NEVER commit .env or any file containing real secrets to version control.

# Environment: "development" or "production"
APP_ENV=development

# Database connection string (SQLAlchemy format)
DATABASE_URL=sqlite:///dividend_genie.db

# Telegram bot token — obtain from @BotFather
TELEGRAM_BOT_TOKEN=

# Alpha Vantage API key — obtain from https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Session signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=
